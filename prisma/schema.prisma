generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  school    String? 
  isAdmin   Boolean  @default(false)
  
  subscriptionStatus   String   @default("free") // free, active, expired
  subscriptionPlan     String?  // monthly, yearly
  subscriptionExpiry   DateTime?
  subscriptionMidtransId String? // Midtrans order ID
  
  createdAt DateTime @default(now())
  rpps      RPP[]
  protas    Prota[]
  promes    Promes[]
  exams     Exam[]
}

model FreeUsage {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RPP {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  mataPelajaran  String
  fase           String
  cp             String?
  kelas          String?
  sekolah        String?
  namaGuru       String?
  tahunAjaran    String?
  semester       String?
  alokasWaktu    String?

  rawOutput      Json
  status         String   @default("draft")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Prota {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  mataPelajaran  String
  fase           String
  kelas          String[]
  sekolah        String?
  namaGuru       String?
  tahunAjaran    String?

  rawOutput      Json
  status         String   @default("draft")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Promes {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  mataPelajaran  String
  fase           String
  kelas          String?
  sekolah        String?
  namaGuru       String?
  tahunAjaran    String?
  semester       String
  jpPerMinggu    String?

  rawOutput      Json
  status         String   @default("draft")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Exam {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  mataPelajaran   String
  jenjang         String?
  kelas           String?
  judul           String
  kodeUjian       String   @unique
  tanggalMulai    DateTime
  tanggalSelesai  DateTime

  questions       ExamQuestion[]
  students        ExamStudent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ExamQuestion {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  pertanyaan  String
  point       Int
  jenis       String   @default("essay") // essay, pilihan_ganda, multiple_answer
  kunciJawaban Json?   // essay: {"text":"..."} / pilihan_ganda: {"pilihan":"b"} / multiple_answer: {"pilihan":["a","c"]}

  choices     ExamQuestionChoice[]
  answers     ExamAnswer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([examId])
}

model ExamQuestionChoice {
  id         String   @id @default(cuid())
  questionId String
  question   ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  label      String   // a, b, c, d
  teks       String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([questionId, label])
  @@index([questionId])
}

model Student {
  id              String         @id @default(cuid())
  email           String         @unique
  nama            String
  password        String
  resetToken      String?        @unique
  resetTokenExpiry DateTime?

  examStudents    ExamStudent[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ExamStudent {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id])

  nama        String
  username    String
  password    String
  startedAt   DateTime @default(now())
  submittedAt DateTime?

  tabSwitchCount Int      @default(0)
  score          Int?
  scoreReleased  Boolean  @default(false)

  answers     ExamAnswer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([examId, username])
  @@index([examId])
  @@index([studentId])
}

model ExamAnswer {
  id            String      @id @default(cuid())
  examStudentId String
  examStudent   ExamStudent @relation(fields: [examStudentId], references: [id], onDelete: Cascade)
  questionId    String
  question      ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  jawaban       String
  score         Int?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([examStudentId, questionId])
  @@index([examStudentId])
  @@index([questionId])
}

model MataPelajaran {
  id          String   @id @default(cuid())
  nama        String   @unique

  fases       Fase[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fase {
  id              String   @id @default(cuid())
  nama            String   // e.g., "Fase A", "Fase B"
  keterangan      String?  // e.g., "Kelas 1 & 2 SD/MI"

  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])

  capaianPembelajarans CapaianPembelajaran[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mataPelajaranId, nama])
}

model CapaianPembelajaran {
  id          String   @id @default(cuid())
  nama        String   // e.g., "Menyimak", "Membaca"
  deskripsi   String

  faseId      String
  fase        Fase     @relation(fields: [faseId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([faseId])
  @@unique([faseId, nama])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}