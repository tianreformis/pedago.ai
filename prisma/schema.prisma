generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  school    String? 
  isAdmin   Boolean  @default(false)
  
  subscriptionStatus   String   @default("free") // free, active, expired
  subscriptionPlan     String?  // monthly, yearly
  subscriptionExpiry   DateTime?
  subscriptionMidtransId String? // Midtrans order ID
  
  createdAt DateTime @default(now())
  rpps      RPP[]
  protas    Prota[]
}

model FreeUsage {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RPP {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  mataPelajaran  String
  fase           String
  cp             String?
  kelas          String?
  sekolah        String?
  namaGuru       String?
  tahunAjaran    String?
  semester       String?
  alokasWaktu    String?

  rawOutput      Json
  status         String   @default("draft")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Prota {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  mataPelajaran  String
  fase           String
  kelas          String[]
  sekolah        String?
  namaGuru       String?
  tahunAjaran    String?

  rawOutput      Json
  status         String   @default("draft")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model MataPelajaran {
  id          String   @id @default(cuid())
  nama        String   @unique

  fases       Fase[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fase {
  id              String   @id @default(cuid())
  nama            String   // e.g., "Fase A", "Fase B"
  keterangan      String?  // e.g., "Kelas 1 & 2 SD/MI"

  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])

  capaianPembelajarans CapaianPembelajaran[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mataPelajaranId, nama])
}

model CapaianPembelajaran {
  id          String   @id @default(cuid())
  nama        String   // e.g., "Menyimak", "Membaca"
  deskripsi   String

  faseId      String
  fase        Fase     @relation(fields: [faseId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([faseId])
  @@unique([faseId, nama])
}